# ─── Anthropic (the sales agent's brain) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Model for the conversational sales agent. claude-opus-4-8 is the most capable.
# For high message volume you can switch to claude-sonnet-4-6 to cut cost ~40%.
ANTHROPIC_MODEL=claude-opus-4-8
# Reasoning effort: low | medium | high | xhigh | max
ANTHROPIC_EFFORT=medium

# ─── WhatsApp transport ────────────────────────────────────────────────────────
# Provider is auto-selected: if Twilio creds are set it uses Twilio; else if Meta
# creds are set it uses Meta; else "console" mode (replies are logged, not sent).

# Option A — Twilio (easiest to test: WhatsApp Sandbox, no Meta verification).
#   Console > Messaging > Try it out > WhatsApp sandbox. Webhook → /webhook/twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The Twilio WhatsApp sender. Sandbox default shown below.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Option B — Meta WhatsApp Cloud API. Webhook → /webhook/whatsapp
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
# Any random string you choose; enter the SAME value in the Meta webhook config.
WHATSAPP_VERIFY_TOKEN=flexiplan-verify-change-me

# ─── Flexiscore credit engine (external API) ───────────────────────────────────
# Your credit-engine endpoint. Leave empty to use the built-in mock scorer so the
# app runs end-to-end today. See src/flexiscore/client.ts for the request contract.
FLEXISCORE_API_URL=
FLEXISCORE_API_KEY=

# ─── Dealer / inventory verification ───────────────────────────────────────────
# Comma-separated ops email(s) notified when a sale needs dealer confirmation.
OPS_NOTIFY_EMAIL=
# Optional outbound email (SMTP) for dealer notices — left unset uses log stub.
SMTP_URL=

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info
