{
  "name": "flexiplan-agent",
  "version": "0.1.0",
  "private": true,
  "description": "AI WhatsApp sales agent for Flexiplan motorcycle financing in El Salvador",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
